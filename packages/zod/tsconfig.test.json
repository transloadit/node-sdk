{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "NodeNext",
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@transloadit/types": ["../types/src/index.ts"],
      "@transloadit/types/*": ["../types/src/generated/*.ts"]
    }
  },
  "include": ["test/type-equality-v3.ts", "test/type-equality-v4.ts", "test/runtime-parity.test.ts"]
}
